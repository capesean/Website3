{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore.SpaProxy": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "KeyVault": {
    "VaultUri": "https://{SET_THIS}.vault.azure.net/"
  },
  "Settings": {
    // client/front-end: must match with the port in package.json -> scripts:start
    "RootUrl": "https://localhost:44401/",
    "SiteName": "{SET_THIS}",
    "UseApplicationInsights": false,
    "AccessTokenExpiryMinutes": 10,
    "RefreshTokenExpiryMinutes": 10880,
    "Email": {
      "SenderName": "some name",
      "Sender": "some_email@some_server.com",
      "SubstitutionEmailAddress": "your@email.com",
      "EmailToErrors": "your@email.com",
      "SendEmails": false,
      "SendErrorEmails": false,
      "SMTP": "your_smtp_server",
      "SMTPPort": 25,
      "SSL": false
    },
    "Azure": {
      "DataProtection": {
        "BlobUri": "https://{SET_THIS}.blob.core.windows.net/dataprotection/dataprotectionkeys.xml",
        "KeyIdentifier": "https://{SET_THIS}.vault.azure.net/keys/dataprotectionkey/{SET_THIS}"
      }
    }
  }
}
